# ──────────────────────────────────────────────
# pptToExamNotes — Environment Configuration
# ──────────────────────────────────────────────
# Copy this file to .env and uncomment the provider you want to use.
#
# LOCAL providers (no API key needed):
#   vllm, ollama
#
# CLOUD providers (API key required):
#   gemini, openai, anthropic, groq, together
# ──────────────────────────────────────────────

# Default provider — uses local vLLM server (start it first!)
LLM_PROVIDER=vllm

# ── vLLM (default — local A100 GPU) ─────────
# Start vLLM server on your GPU machine:
#   python -m vllm.entrypoints.openai.api_server \
#       --model Qwen/Qwen2.5-72B-Instruct-AWQ \
#       --quantization awq \
#       --max-model-len 32768 \
#       --gpu-memory-utilization 0.95 \
#       --port 8000
#
# VLLM_BASE_URL=http://localhost:8000/v1
# VLLM_MODEL=Qwen/Qwen2.5-72B-Instruct-AWQ

# ── Ollama (local alternative) ──────────────
# Start Ollama:  ollama pull qwen2.5:72b && ollama serve
#
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_MODEL=qwen2.5:72b

# ── Google Gemini (cloud) ───────────────────
# GEMINI_API_KEY=your_gemini_api_key_here
# GEMINI_MODEL=gemini-2.0-flash

# ── OpenAI (cloud) ──────────────────────────
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_MODEL=gpt-4o

# ── Anthropic Claude (cloud) ────────────────
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ── Groq (cloud, fast Llama) ────────────────
# GROQ_API_KEY=your_groq_api_key_here
# GROQ_MODEL=llama-3.3-70b-versatile

# ── Together AI (cloud) ─────────────────────
# TOGETHER_API_KEY=your_together_api_key_here
# TOGETHER_MODEL=meta-llama/Llama-3.3-70B-Instruct-Turbo
